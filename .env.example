# ==========================================
# FILE DI CONFIGURAZIONE DI ESEMPIO (.env.example)
# ==========================================

# Password del Database di Keycloak (auth-net)
DB_AUTH_PASSWORD=KeycloakAuthSecretPass123!

# Password dell'Amministratore Keycloak
KEYCLOAK_ADMIN_PASSWORD=KeycloakAdminSecretPass123!

# Client Secret di OAuth2-Proxy registrato in Keycloak
OAUTH2_PROXY_CLIENT_SECRET=OAuth2ProxyClientSecretKey123!

# Cookie Secret per cifrare la sessione di OAuth2-Proxy
COOKIE_SECRET=c3VwZXJzZWNyZXRjb29raWVzZWNyZXQ=
