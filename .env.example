# ==========================================
# FILE DI CONFIGURAZIONE DI ESEMPIO (.env.example)
# ==========================================

# Dominio pubblico dell'applicazione
DOMAIN=your_domain_here
SCHEME=https

# Password del Database di Keycloak (auth-net)
DB_AUTH_PASSWORD=your_keycloak_db_password_here

# Password dell'Amministratore Keycloak
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password_here

# Client Secret di OAuth2-Proxy registrato in Keycloak
OAUTH2_PROXY_CLIENT_SECRET=your_secure_oauth2_proxy_client_secret_here

# Cookie Secret per cifrare la sessione di OAuth2-Proxy (deve essere a 32 byte e in Base64)
# Puoi generarne uno con: openssl rand -base64 32
COOKIE_SECRET=your_base64_cookie_secret_here

# Password per il database applicativo (postgres-app)
DB_APP_PASSWORD=your_app_database_password_here
